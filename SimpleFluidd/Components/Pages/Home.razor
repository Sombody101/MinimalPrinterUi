@page "/"
@rendermode InteractiveServer
@using Humanizer;
@using SimpleFluidd.Services;
@using Models;
@using Newtonsoft.Json;
@using SimpleFluidd.Configuration;

@implements IDisposable
@inject PrinterCoordinator Coordinator
@inject ContainerConfig _config;
@inject ILogger<Home> _logger;

@code {
    private MoonrakerData Status;

    private bool _isRetrying;

    private PrinterCamera? _selectedCamera;
    private string? SelectedCameraUrl => _selectedCamera?.StreamUrl;

    protected override void OnInitialized()
    {
        Status = Coordinator.PrinterStatus;
        Coordinator.OnDataUpdated += HandleUpdate;

        if (_selectedCamera is null)
        {
            _selectedCamera = Coordinator.Cameras.FirstOrDefault();
        }
    }

    private void OnCameraChanged(ChangeEventArgs e)
    {
        string? streamUrl = e.Value as string;
        if (streamUrl is null)
        {
            return;
        }

        _selectedCamera = Coordinator.Cameras.FirstOrDefault(c => c.StreamUrl == streamUrl);
    }

    private async void HandleUpdate()
    {
        Status = Coordinator.PrinterStatus;

        if (Status is null)
        {
            return;
        }

        _logger.LogDebug("Cam count: {Count}, Null: {Null}", Coordinator.Cameras.Count, _selectedCamera?.Name ?? "Null");
        if (_selectedCamera is null && Coordinator.Cameras.Any())
        {
            _selectedCamera = Coordinator.Cameras.FirstOrDefault();
        }

        await InvokeAsync(() => StateHasChanged());
    }

    public void Dispose()
    {
        Coordinator.OnDataUpdated -= HandleUpdate;
    }

    private string GenerateSvg()
    {
        return Coordinator.GenerateBlueprint(Coordinator.CurrentPolygons);
    }

    private string GetThwartedUrl(string baseUrl)
    {
        if (string.IsNullOrEmpty(baseUrl))
        {
            return string.Empty;
        }

        return $"{baseUrl}{(baseUrl.Contains('?') ? '&' : '?')}t={DateTime.Now.Ticks}";
    }
}

<div class="camera-container">
    @if (Coordinator.Cameras is not null && Coordinator.Cameras.Any())
    {
        <div class="camera-layout">
            <div class="controls mb-2">
                <label for="cameraSelect" class="form-label">Select Camera:</label>
                <select id="cameraSelect" class="form-select" @onchange="OnCameraChanged">
                    @foreach (var cam in Coordinator.Cameras)
                    {
                        <option value="@cam.StreamUrl">@cam.Name</option>
                    }
                </select>
            </div>

            <div class="video-wrapper">
                @if (_selectedCamera is not null)
                {
                    switch (_selectedCamera.ServiceType)
                    {
                        case "mjpegstreamer":
                            <img class="video-content" src="@SelectedCameraUrl">
                            break;
                        case "iframe":
                            <iframe class="video-content" src="@SelectedCameraUrl" allowfullscreen></iframe>
                            break;
                    }
                }
                else
                {
                    <p class="error-text">Failed to load camera</p>
                }
            </div>
        </div>
    }
</div>

<div class="printer-dashboard status-@(Status.PrintStats?.State)">
    <div class="stats-grid" hidden="@Coordinator.PrinterOnline">
    <Callout Color="CalloutColor.Warning" style="border-radius: 4px; max-width: 800px;">
        <strong>Unable to reach printer!</strong>
    </Callout>
    </div>
    <div class="stats-grid">
        <div class="stat-card">
            <div class="card-columns">
                <div class="column">
                    <span class="stat-label">Hotend</span>
                    <div class="stat-value">@Status.Extruder?.Temperature°C / @Status.Extruder?.TargetTemp°C</div>
    
                    <span class="stat-label">Bed</span>
                    <div class="stat-value">@Status.Bed?.Temperature°C / @Status.Bed?.TargetTemp°C</div>
                </div>
    
                <div class="column">
                    @code {
                        RenderFragment RenderFan(string label, string value, bool isOn) => __builder =>
                        {
                            <span class="stat-label">@label</span>
                            <div class="stat-value">
                                @value
                                @if (isOn)
                                {
                                    <span class="spin">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-fan">
                                            <path d="M10.827 16.379a6.082 6.082 0 0 1-8.618-7.002l5.412 1.45a6.082 6.082 0 0 1 7.002-8.618l-1.45 5.412a6.082 6.082 0 0 1 8.618 7.002l-5.412-1.45a6.082 6.082 0 0 1-7.002 8.618l1.45-5.412Z" />
                                            <path d="M12 12v.01" />
                                        </svg>
                                    </span>
                                }
                            </div>
                        };
                    }

                    <div class="column">
                        @RenderFan("Hotend fan", Status.HotendFan?.On ?? false ? "On" : "Off", Status.HotendFan?.On ?? false)
                        @RenderFan("Part cooler", $"{Coordinator.PrinterStatus.PartFan?.PowerPercentage:F0}%", Coordinator.PrinterStatus.PartFan?.On ?? false)
                    </div>
                </div>
            </div>
        </div>
    
        <div class="stat-card">
            <span class="stat-label">Print progress</span>
            <div class="stat-value">
                <Progress Class="mb-3">
                    <ProgressBar 
                        Type="ProgressType.StripedAndAnimated" 
                        Width="@(Status.DisplayStatus?.PrintProgressPercent ?? 0)" 
                        Label="@($"{Status.DisplayStatus?.PrintProgressPercent ?? 0}%")" />
                </Progress>
            </div>
            <span class="stat-label">Current layer</span>
            <div class="stat-value">@(Status.PrintStats?.Info.PresentableLayers)</div>
            <span class="stat-label">Print time</span>
            <div class="stat-value">
                @TimeSpan.FromSeconds(Status?.PrintStats?.PrintDuration ?? 0).Humanize(precision: 2)
            </div>
        </div>
    </div>
    
    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-label">State</span>
            <div class="stat-value">@(Status.PrintStats?.State.ApplyCase(LetterCasing.Title))</div>
            <span class="stat-label">File</span>
            <div class="stat-value">@(Status.PrintStats?.Filename)</div>
            <span class="stat-label">Message</span>
            <div class="stat-value">@(Status.PrintStats?.Message)</div>
        </div>
    </div>
</div>

<div class="blueprint container">
    <div class="blueprint">
        <svg viewBox="0 0 250 250">
            <defs>
                <pattern id="smallGrid" width="10" height="10" patternUnits="userSpaceOnUse">
                    <path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5" />
                </pattern>
                <pattern id="grid" width="50" height="50" patternUnits="userSpaceOnUse">
                    <rect width="50" height="50" fill="url(#smallGrid)" />
                    <path d="M 50 0 L 0 0 0 50" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
                </pattern>
            </defs>

            <rect x="0.5" y="0.5" width="249" height="249" rx="2" ry="2" fill="url(#grid)" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
            @((MarkupString)GenerateSvg())
        </svg>
    </div>
</div>

<style>
    .controls {
        display: block;
    }

    .controls div {
        max-width: 800px;
        justify-content: center;
    }

    .video.container {
        display: flex;
        justify-content: center;
        width: 100%;
        padding: 1rem 0;
    }

    .video-wrapper {
        width: 100%;
        max-width: 1200px;
        aspect-ratio: 16 / 9;
        background: #000;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #333;
        position: relative;
    }

    .video-wrapper iframe {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
    }

    .camera-layout {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
    }

    .controls {
        margin-bottom: 0.5rem;
    }

    #cameraSelect {
        display: block;
    }

    .video-wrapper {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: #000;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #333;
        position: relative;
        min-width: 300px;
    }

    .video-content {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
        object-fit: contain;
    }

    .error-text {
        color: #888;
        padding: 2rem;
        text-align: center;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
        width: 100%;
        max-width: 800px;
        margin: 0 auto 1rem auto;
    }

    .stat-card {
        background: #202022;
        padding: 15px;
        border-radius: 8px;
        border-left: 4px solid #007bff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .stat-label {
        color: #888;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .stat-value {
        color: #fff;
        font-size: 1.4rem;
        font-weight: bold;
        margin: 5px 0;
    }

    .stat-bar {
        height: 4px;
        background: #444;
        border-radius: 2px;
        overflow: hidden;
    }

    .stat-bar .fill {
        height: 100%;
        background: #00d4ff;
        transition: width 0.5s ease;
    }

    .card-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        width: 100%;
    }

    .column {
        display: flex;
        flex-direction: column;
    }
    
    .column:first-child {
        border-right: 1px solid rgba(255,255,255,0.05);
        padding-right: 10px;
    }

    .blueprint.container {
        display: flex;
        justify-content: center;
        width: 100%;
        padding: 1rem 0;
        margin-bottom: 30px;
    }
    
    .blueprint {
        width: 100%;
        max-width: 800px; 
        aspect-ratio: 1 / 1; 
        background: #1a1a1a;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
    }
    
    .blueprint svg {
        display: block;
        width: 100%;
        height: 100%;
    }

    .spinning-icon {
        display: inline-block;
        animation: spin 2s linear infinite;
        font-size: 0.8rem;
    }

    .spin {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-left: 5px;
    }

    .spin svg {
        width: 20px; 
        height: 20px;
        animation: spin-keys 2s linear infinite;
    }

    @@keyframes spin-keys {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>